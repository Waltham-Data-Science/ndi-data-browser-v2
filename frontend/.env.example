# ──────────────────────────────────────────────────────────────────────
# ndi-data-browser-v2 / frontend — environment variables
#
# Copy to `.env.local` for local dev, or set in your deployment host's
# environment (Railway, Vercel, etc.). All vars must be prefixed `VITE_`
# to be exposed to the browser at build time.
# ──────────────────────────────────────────────────────────────────────

# Base URL of the marketing/auth site.
# Used for cross-domain nav links from the data browser back to marketing
# pages (About, Platform, LabChat, etc.) and for the Create-Free-Account
# CTA (auth lives on the marketing site during staging).
#
# Prod:     https://ndi-cloud.com
# Staging:  https://staging.ndi-cloud.com
# Local:    http://localhost:3000  (if running ndi-web-app-wds on :3000)
VITE_MARKETING_URL=https://ndi-cloud.com
