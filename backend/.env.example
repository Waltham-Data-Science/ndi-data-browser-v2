# --- Required ---
NDI_CLOUD_URL=https://api.ndi-cloud.com/v1
REDIS_URL=redis://localhost:6379/0
# 32-byte Fernet key, base64-url-safe. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_ENCRYPTION_KEY=changeme_generate_a_real_key
# 32 bytes hex for CSRF signing. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
CSRF_SIGNING_KEY=changeme_64_hex_chars

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# --- Session TTLs (seconds) ---
SESSION_IDLE_TTL_SECONDS=7200
SESSION_ABSOLUTE_TTL_SECONDS=86400

# --- Cloud client ---
CLOUD_HTTP_TIMEOUT_SECONDS=30
CLOUD_MAX_RETRIES=3
CLOUD_CIRCUIT_BREAKER_THRESHOLD=5
CLOUD_CIRCUIT_BREAKER_COOLDOWN_SECONDS=30
CLOUD_POOL_SIZE=50

# --- Rate limits (per minute or as noted) ---
RATE_LIMIT_READS_PER_MIN=120
RATE_LIMIT_QUERY_PER_MIN=30
RATE_LIMIT_BULK_FETCH_PER_MIN=10
RATE_LIMIT_LOGIN_PER_IP_15MIN=5
RATE_LIMIT_LOGIN_PER_USER_HOUR=10

# --- Ontology cache ---
ONTOLOGY_CACHE_DB_PATH=/tmp/ndi-ontology.db
ONTOLOGY_CACHE_TTL_DAYS=30

# --- Observability ---
LOG_LEVEL=INFO
LOG_FORMAT=json
ENVIRONMENT=development

# --- Download host allowlist (audit 2026-04-23 SSRF hardening, issue #49) ---
# NdiCloudClient.download_file() fetches signed URLs the cloud embeds in
# document `files` metadata. A malicious or compromised dataset could point
# that URL at internal infrastructure (AWS metadata 169.254.169.254, Railway
# Redis, etc.) — SSRF. We hard-reject any URL whose host does not suffix-match
# an entry below, plus the cloud host (added automatically at runtime).
#
# Wildcard entries start with "*." and match both the bare suffix and any
# subdomain. Off-allowlist URLs raise BINARY_NOT_FOUND (404) and log
# `cloud.download.off_allowlist_host`. Non-http(s) schemes are always rejected.
DOWNLOAD_HOST_ALLOWLIST=s3.amazonaws.com,*.s3.amazonaws.com,*.s3.us-east-1.amazonaws.com,*.s3.us-east-2.amazonaws.com,*.s3.us-west-1.amazonaws.com,*.s3.us-west-2.amazonaws.com,*.cloudfront.net
