# --- Required ---
NDI_CLOUD_URL=https://api.ndi-cloud.com/v1
REDIS_URL=redis://localhost:6379/0
# 32-byte Fernet key, base64-url-safe. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_ENCRYPTION_KEY=changeme_generate_a_real_key
# 32 bytes hex for CSRF signing. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
CSRF_SIGNING_KEY=changeme_64_hex_chars

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# --- Session TTLs (seconds) ---
SESSION_IDLE_TTL_SECONDS=7200
SESSION_ABSOLUTE_TTL_SECONDS=86400
ACCESS_TOKEN_REFRESH_GRACE_SECONDS=60

# --- Cloud client ---
CLOUD_HTTP_TIMEOUT_SECONDS=30
CLOUD_MAX_RETRIES=3
CLOUD_CIRCUIT_BREAKER_THRESHOLD=5
CLOUD_CIRCUIT_BREAKER_COOLDOWN_SECONDS=30
CLOUD_POOL_SIZE=50

# --- Rate limits (per minute or as noted) ---
RATE_LIMIT_READS_PER_MIN=120
RATE_LIMIT_QUERY_PER_MIN=30
RATE_LIMIT_BULK_FETCH_PER_MIN=10
RATE_LIMIT_LOGIN_PER_IP_15MIN=5
RATE_LIMIT_LOGIN_PER_USER_HOUR=10

# --- Ontology cache ---
ONTOLOGY_CACHE_DB_PATH=/tmp/ndi-ontology.db
ONTOLOGY_CACHE_TTL_DAYS=30

# --- Observability ---
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=
ENVIRONMENT=development

# --- Download host allowlist (PR-6 security fix) ---
# NdiCloudClient.download_file() forwards the user's Cognito Bearer to whatever
# signed URL the cloud returns in a document's `files` metadata. A malicious
# dataset could redirect that URL to an attacker host and capture the token.
# To mitigate, only forward the Bearer when the URL's host suffix-matches an
# entry below. Wildcard entries start with "*." and match both the bare suffix
# and any subdomain. The cloud host from NDI_CLOUD_URL is added automatically
# at runtime — you do NOT need to list it here.
#
# Rollout is two-phase:
#   Phase 1 (DOWNLOAD_ALLOWLIST_ENFORCE=false, default): log a warning for any
#     download to a non-allowlisted host but still forward the Bearer. Lets us
#     observe which hosts legitimately appear in production over ~1 week.
#   Phase 2 (DOWNLOAD_ALLOWLIST_ENFORCE=true): strip the Authorization header
#     when host is not allowlisted. Flip to true in Railway env after reviewing
#     phase-1 `cloud.download.off_allowlist_host` log volume.
DOWNLOAD_HOST_ALLOWLIST=s3.amazonaws.com,*.s3.amazonaws.com,*.s3.us-east-1.amazonaws.com,*.s3.us-east-2.amazonaws.com,*.s3.us-west-1.amazonaws.com,*.s3.us-west-2.amazonaws.com,*.cloudfront.net
DOWNLOAD_ALLOWLIST_ENFORCE=false
